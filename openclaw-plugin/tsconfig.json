{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "paths": {
      "../scrapers/*": ["../scrapers/*"],
      "../read-local-passwords/*": ["../read-local-passwords/*"],
      "../shared/*": ["../shared/*"]
    }
  },
  "include": ["src"]
}
