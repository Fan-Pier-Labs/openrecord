{
  "compilerOptions": {
    "target": "es6",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "rootDir": ".",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "moduleResolution": "Node",
    "module": "commonjs",
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "sourceMap": false,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "strictNullChecks": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["electron-app/renderer/renderer/*"],
      "@/components/*": ["electron-app/renderer/renderer/components/*"],
      "@/ui/*": ["electron-app/renderer/renderer/components/ui*"],
      "@/lib/*": ["electron-app/renderer/renderer/lib/*"],
      "@/hooks/*": ["electron-app/renderer/renderer/hooks/*"],
      "@/pages/*": ["electron-app/renderer/renderer/pages/*"]
    }
  },
  "include": [
    "index.d.ts",
    "scrapers/**/*.ts",
    "cli/**/*.ts",
    "shared/**/*.ts",
    "electron-app/**/*.ts",
    "electron-app/**/*.tsx",
    "read-local-passwords/**/*.ts",
    "clo-to-jpg-converter/**/*.ts"
  ]
}
